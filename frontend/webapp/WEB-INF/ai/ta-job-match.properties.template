# TA job match AI config template
# Copy this file to ta-job-match.local.properties and fill real secrets locally.
# The .local.properties file is ignored by git.

# DashScope API key (required)
dashscope.api.key=REPLACE_WITH_REAL_DASHSCOPE_API_KEY

# OpenAI-compatible base URL
ta.job.match.ai.base-url=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model name
ta.job.match.ai.model=tongyi-xiaomi-analysis-flash

# Request timeout (milliseconds)
ta.job.match.ai.timeout-ms=6000
